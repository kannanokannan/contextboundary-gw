{
  "credential-patterns": {
    "max_payload_chars": 65536,
    "patterns": [
      "-----BEGIN [A-Z ]*PRIVATE KEY-----",
      "\\b(?:api[_-]?(?:key|secret)|access[_-]?token|client[_-]?secret|password)\\s*[:=]\\s*[\"']?[A-Za-z0-9_./+=-]{8,}",
      "\\b(?:secret|token)_[A-Za-z0-9_-]{12,}\\b"
    ]
  }
}
